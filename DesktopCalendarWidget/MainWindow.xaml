<Window x:Class="DesktopCalendarWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="Desktop Calendar Widget" 
        Height="600" Width="400"
        MinHeight="400" MinWidth="300"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Built-in converters -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Styles -->
        <Style x:Key="EventStyle" TargetType="Border">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{Binding CalendarColor}"/>
            <Setter Property="Opacity" Value="0.8"/>
        </Style>
        
        <!-- Style for TextBlock with conditional formatting -->
        <Style x:Key="DayTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsToday}" Value="True">
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                    <Setter Property="Foreground" Value="LightGray"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style for calendar day border with conditional background -->
        <Style x:Key="DayBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="MinHeight" Value="60"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsToday}" Value="True">
                    <Setter Property="Background" Value="LightBlue"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Style for location text with visibility based on content -->
        <Style x:Key="LocationTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Location}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Location}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- System Tray Icon -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="icon.ico"
                        ToolTipText="Desktop Calendar Widget"
                        MenuActivation="RightClick"
                        LeftClickCommand="{Binding ToggleVisibilityCommand}">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Settings" Command="{Binding ShowSettingsCommand}"/>
                    <MenuItem Header="Refresh" Command="{Binding RefreshCommand}"/>
                    <Separator/>
                    <MenuItem Header="Exit" Command="{Binding ExitCommand}"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Main Widget Content -->
        <Border Background="{DynamicResource MaterialDesignPaper}"
                CornerRadius="8"
                Margin="10"
                Effect="{StaticResource MaterialDesignShadowDepth3}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" 
                        Background="{DynamicResource PrimaryHueMidBrush}"
                        CornerRadius="8,8,0,0"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding CurrentDate, StringFormat='MMMM yyyy'}"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="12,8"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="White"
                                Command="{Binding ShowSettingsCommand}"
                                ToolTip="Settings">
                            <materialDesign:PackIcon Kind="Settings"/>
                        </Button>

                        <Button Grid.Column="2"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="White"
                                Command="{Binding MinimizeCommand}"
                                ToolTip="Minimize to tray">
                            <materialDesign:PackIcon Kind="WindowMinimize"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Calendar Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <!-- Navigation -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding PreviousMonthCommand}">
                                <materialDesign:PackIcon Kind="ChevronLeft"/>
                            </Button>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentDate, StringFormat='MMMM yyyy'}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>

                            <Button Grid.Column="2"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding NextMonthCommand}">
                                <materialDesign:PackIcon Kind="ChevronRight"/>
                            </Button>
                        </Grid>

                        <!-- Days of Week Header -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Sun" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="2"/>
                            <TextBlock Grid.Column="1" Text="Mon" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="2"/>
                            <TextBlock Grid.Column="2" Text="Tue" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="2"/>
                            <TextBlock Grid.Column="3" Text="Wed" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="2"/>
                            <TextBlock Grid.Column="4" Text="Thu" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="2"/>
                            <TextBlock Grid.Column="5" Text="Fri" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="2"/>
                            <TextBlock Grid.Column="6" Text="Sat" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="2"/>
                        </Grid>

                        <!-- Calendar Days -->
                        <ItemsControl ItemsSource="{Binding CalendarDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="6" Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DayBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Day}"
                                                       Style="{StaticResource DayTextStyle}"/>
                                            
                                            <ItemsControl ItemsSource="{Binding Events}" Margin="1">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource EventStyle}"
                                                                Background="{Binding CalendarColor}"
                                                                ToolTip="{Binding Title}">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="8"
                                                                       Foreground="White"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Today's Events -->
                        <Expander Header="Today's Events" IsExpanded="True" Margin="0,8,0,0">
                            <ItemsControl ItemsSource="{Binding TodaysEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource EventStyle}"
                                                Background="{Binding CalendarColor}"
                                                Margin="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding StartDate, StringFormat='HH:mm'}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           Margin="4,2"/>
                                                
                                                <StackPanel Grid.Column="1" Margin="4,2">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="White"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Location}"
                                                               Style="{StaticResource LocationTextStyle}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer with sync status -->
                <Border Grid.Row="2"
                        Background="{DynamicResource MaterialDesignDivider}"
                        CornerRadius="0,0,8,8"
                        Padding="8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding LastSyncTime, StringFormat='Last sync: {0:HH:mm}'}"
                                   FontSize="10"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Command="{Binding RefreshCommand}"
                                Width="20" Height="20">
                            <materialDesign:PackIcon Kind="Refresh" Width="12" Height="12"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>