<Window x:Class="DesktopCalendarWidget.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:DesktopCalendarWidget.Converters"
        Title="Calendar Settings" 
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Converter needed for this window -->
        <converters:NullToBooleanConverter x:Key="NullToBooleanConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource PrimaryHueMidBrush}"
                Padding="16">
            <TextBlock Text="Calendar Settings"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"/>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Calendar List -->
            <GroupBox Grid.Column="0" Header="Calendars" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="CalendarListBox"
                             Grid.Row="0"
                             ItemsSource="{Binding Calendars}"
                             SelectedItem="{Binding SelectedCalendar}"
                             DisplayMemberPath="Name"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Add" 
                                Command="{Binding AddCalendarCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Margin="0,0,8,0"/>
                        <Button Content="Remove" 
                                Command="{Binding RemoveCalendarCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Calendar Details -->
            <GroupBox Grid.Column="1" Header="Calendar Details" Margin="8,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding SelectedCalendar}" IsEnabled="{Binding DataContext.SelectedCalendar, RelativeSource={RelativeSource AncestorType=GroupBox}, Converter={StaticResource NullToBooleanConverter}}">
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Name:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CalDAV URL:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Username:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Password:" VerticalAlignment="Center"/>
                            <PasswordBox x:Name="PasswordBox" Grid.Column="1" Margin="8,0,0,0" PasswordChanged="PasswordBox_PasswordChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Color:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}" Margin="8,0,8,0"/>
                            <Rectangle Grid.Column="2" Width="30" Height="20" Fill="{Binding Color}" Stroke="Black" StrokeThickness="1"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Sync Interval:" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" 
                                    Value="{Binding SyncIntervalMinutes}" 
                                    Minimum="5" Maximum="120" 
                                    TickFrequency="5" 
                                    IsSnapToTickEnabled="True"
                                    Margin="8,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding SyncIntervalMinutes, StringFormat='{0} min'}" VerticalAlignment="Center"/>
                        </Grid>

                        <CheckBox Content="Enabled" IsChecked="{Binding IsEnabled}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LastSync, StringFormat='Last sync: {0:yyyy-MM-dd HH:mm}'}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" 
                                    Content="Test Connection" 
                                    Command="{Binding DataContext.TestConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </Grid>

                        <!-- Predefined Nextcloud Setup -->
                        <Expander Header="Quick Setup for Nextcloud" IsExpanded="False" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="For Nextcloud, use this URL format:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Text="https://your-nextcloud-domain/remote.php/dav/calendars/USERNAME/CALENDAR_NAME/" 
                                           Background="LightGray" 
                                           Padding="8" 
                                           FontFamily="Consolas"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Example:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="https://cloud.example.com/remote.php/dav/calendars/john/personal/"
                                           Background="LightGray"
                                           Padding="8"
                                           FontFamily="Consolas"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" 
                Background="{DynamicResource MaterialDesignDivider}"
                Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" 
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,0,8,0"/>
                <Button Content="Cancel" 
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>